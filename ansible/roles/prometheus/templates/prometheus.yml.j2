global:
  scrape_interval: {{ prometheus_scrape_interval }}

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - '127.0.0.1:{{ prometheus_port }}'
{% if groups['compute_gpu'] | length > 0 %}
  - job_name: dcgm_exporter
    static_configs:
      - targets:
{% for node in groups['compute_gpu'] | sort %}
          - '{{ node }}:{{ dcgm_exporter_port }}'
{% endfor %}
{% endif %}
